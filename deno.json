{
  "name": "@schlp/open-meteo-mcp-ts",
  "version": "4.0.0",
  "exports": "./src/main.ts",
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-read --allow-env src/main.ts",
    "start": "deno run --allow-net --allow-read --allow-env src/main.ts",
    "test": "deno test --allow-net --allow-read",
    "test:watch": "deno test --watch --allow-net --allow-read",
    "coverage": "deno test --coverage=coverage --allow-net --allow-read && deno coverage coverage --lcov > coverage.lcov",
    "bench": "deno bench --allow-net --allow-read",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "check": "deno check src/**/*.ts tests/**/*.ts"
  },
  "imports": {
    "@modelcontextprotocol/sdk": "npm:@modelcontextprotocol/sdk@^1.0.0",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/async": "jsr:@std/async@^1.0.0",
    "@std/log": "jsr:@std/log@^0.224.0",
    "@std/path": "jsr:@std/path@^1.0.0",
    "@std/testing": "jsr:@std/testing@^1.0.0",
    "zod": "npm:zod@^3.24.1",
    "date-fns": "npm:date-fns@^4.1.0",
    "date-fns-tz": "npm:date-fns-tz@^3.2.0"
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "lib": ["deno.window", "deno.unstable"]
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false,
    "proseWrap": "preserve",
    "include": ["src/", "tests/", "benchmarks/"],
    "exclude": ["coverage/", "dist/"]
  },
  "lint": {
    "include": ["src/", "tests/"],
    "exclude": ["coverage/", "dist/"],
    "rules": {
      "tags": ["recommended"],
      "include": ["no-unused-vars"],
      "exclude": ["no-explicit-any"]
    }
  },
  "test": {
    "include": ["tests/**/*.test.ts"],
    "exclude": ["coverage/"]
  },
  "lock": true
}
