{
  "name": "@schlp/open-meteo-mcp-ts",
  "version": "4.2.0",
  "description": "Open-Meteo MCP Server - Weather data via Model Context Protocol",
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "open-meteo-mcp": "dist/main.js"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "start": "node dist/main.js",
    "dev": "node --import tsx src/main.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "watch": "tsc --watch",
    "prebuild": "pnpm clean",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:watch": "node --import tsx --watch --test tests/*.test.ts",
    "coverage": "node --import tsx --test --coverage tests/*.test.ts",
    "lint": "eslint src tests",
    "fmt": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "fmt:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "check": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "weather",
    "open-meteo",
    "claude",
    "model-context-protocol"
  ],
  "author": "Open Meteo Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/schlp/open-meteo-mcp-ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "hono": "^4.12.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "globals": "^16.0.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
